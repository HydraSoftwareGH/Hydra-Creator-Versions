    def mostrar_terminal(self):
        self.modo_actual = "terminal"
        self.btn_terminal.config(bg="#50fa7b", fg="#1e1e2e")
        self.btn_editor.config(bg="#2d2d3d", fg="#e0e0e0")
        
        self.editor_frame.pack_forget()
        
        if not self.terminal_panel:
            self.terminal_panel = TerminalPanel(self.contenido_frame, self.ruta_proyecto, self.lenguaje)
        else:
            self.terminal_panel.frame.pack(fill=tk.BOTH, expand=True)
    
    def cargar_archivo(self):
        try:
            with open(self.archivo_actual, "r", encoding="utf-8") as f:
                contenido = f.read()
            self.code_editor.delete("1.0", tk.END)
            self.code_editor.insert("1.0", contenido)
        except Exception as e:
            self.output_area.insert(tk.END, f"❌ Error al cargar: {str(e)}\n", "error")
    
    def guardar_archivo(self):
        try:
            contenido = self.code_editor.get("1.0", tk.END).strip()
            with open(self.archivo_actual, "w", encoding="utf-8") as f:
                f.write(contenido)
            self.output_area.insert(tk.END, "✅ Archivo guardado\n", "resultado")
            self.output_area.see(tk.END)
        except Exception as e:
            self.output_area.insert(tk.END, f"❌ Error al guardar: {str(e)}\n", "error")
    
    def ejecutar_codigo(self):
        self.guardar_archivo()
        
        comando = LENGUAJES_CONFIG.get(self.lenguaje, {}).get("comandos", {}).get("ejecutar")
        if not comando:
            self.output_area.insert(tk.END, f"⚠️ No hay comando de ejecución para {self.lenguaje}\n", "error")
            return
        
        archivo = self.archivo_actual
        archivo_sin_ext = os.path.splitext(archivo)[0]
        nombre_clase = os.path.basename(archivo_sin_ext)
        
        comando = comando.format(archivo=archivo, archivo_sin_ext=archivo_sin_ext, nombre_clase=nombre_clase)
        
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"🔄 Ejecutando: {comando}\n\n", "titulo")
        self.output_area.see(tk.END)
        
        def ejecutar():
            try:
                if self.lenguaje == "html":
                    import webbrowser
                    webbrowser.open(f'file://{archivo}')
                    resultado = "HTML abierto en el navegador"
                else:
                    proceso = subprocess.run(comando, shell=True, capture_output=True, text=True, timeout=30, cwd=os.path.dirname(archivo))
                    resultado = proceso.stdout if proceso.stdout else "(sin salida)"
                    if proceso.stderr:
                        resultado += f"\n⚠️ {proceso.stderr}"
                
                self.parent.after(0, lambda: self._mostrar_resultado(resultado, proceso.returncode if 'proceso' in dir() else 0))
            except subprocess.TimeoutExpired:
                self.parent.after(0, lambda: self._mostrar_error("Timeout - El código tardó demasiado"))
            except Exception as e:
                self.parent.after(0, lambda: self._mostrar_error(str(e)))
        
        threading.Thread(target=ejecutar, daemon=True).start()
    
    def compilar_codigo(self):
        comando = LENGUAJES_CONFIG.get(self.lenguaje, {}).get("comandos", {}).get("compilar")
        if not comando:
            self.output_area.insert(tk.END, f"⚠️ No hay comando de compilación para {self.lenguaje}\n", "error")
            return
        
        archivo = self.archivo_actual
        archivo_sin_ext = os.path.splitext(archivo)[0]
        
        comando = comando.format(archivo=archivo, archivo_sin_ext=archivo_sin_ext)
        
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"🔨 Compilando: {comando}\n\n", "titulo")
        self.output_area.see(tk.END)
        
        def compilar():
            try:
                proceso = subprocess.run(comando, shell=True, capture_output=True, text=True, timeout=60, cwd=os.path.dirname(archivo))
                if proceso.returncode == 0:
                    resultado = "✅ Compilación exitosa!\n" + (proceso.stdout if proceso.stdout else "")
                else:
                    resultado = f"❌ Error de compilación:\n{proceso.stderr}"
                
                self.parent.after(0, lambda: self._mostrar_resultado(resultado, proceso.returncode))
            except Exception as e:
                self.parent.after(0, lambda: self._mostrar_error(str(e)))
        
        threading.Thread(target=compilar, daemon=True).start()
    
    def crear_exe(self):
        comando_base = LENGUAJES_CONFIG.get(self.lenguaje, {}).get("comandos", {}).get("exe")
        if not comando_base:
            self.output_area.insert(tk.END, f"⚠️ No hay comando para crear EXE en {self.lenguaje}\n", "error")
            return

        archivo = self.archivo_actual
        if self.lenguaje != "python":
            self.output_area.insert(tk.END, f"⚠️ Solo se puede generar EXE para proyectos Python.\n", "error")
            return

        # Verificar PyInstaller
        try:
            subprocess.run([sys.executable, "-m", "PyInstaller", "--version"], capture_output=True, check=True)
        except subprocess.CalledProcessError:
            self.output_area.insert(tk.END, "❌ PyInstaller no está instalado. Ejecuta: pip install pyinstaller\n", "error")
            return
        except FileNotFoundError:
            self.output_area.insert(tk.END, "❌ No se pudo ejecutar Python.\n", "error")
            return

        # Pedir ubicación del ejecutable final
        default_filename = f"{self.datos['nombre']}.exe"
        exe_path = filedialog.asksaveasfilename(
            defaultextension=".exe",
            initialfile=default_filename,
            filetypes=[("Archivos ejecutables", "*.exe"), ("Todos los archivos", "*.*")],
            title="Guardar ejecutable como"
        )
        if not exe_path:
            return

        # Opciones adicionales: ícono
        icon_path = None
        if messagebox.askyesno("Ícono", "¿Quieres asignar un ícono personalizado (.ico)?"):
            icon_path = filedialog.askopenfilename(
                title="Seleccionar archivo .ico",
                filetypes=[("Archivos de ícono", "*.ico"), ("Todos los archivos", "*.*")]
            )
            if icon_path:
                self.output_area.insert(tk.END, f"Ícono seleccionado: {icon_path}\n", "info")

        # Opciones adicionales: archivos extra
        add_data = []
        if messagebox.askyesno("Archivos adicionales", "¿Incluir archivos adicionales en el EXE (imágenes, config, etc.)?"):
            files = filedialog.askopenfilenames(title="Seleccionar archivos adicionales")
            for f in files:
                add_data.append(f'"{f};."')
            if add_data:
                self.output_area.insert(tk.END, f"Archivos adicionales: {len(add_data)}\n", "info")

        dest_dir = os.path.dirname(exe_path)
        exe_name = os.path.basename(exe_path)
        if exe_name.lower().endswith(".exe"):
            exe_name = exe_name[:-4]

        temp_build = os.path.join(os.path.dirname(archivo), "temp_build")
        os.makedirs(temp_build, exist_ok=True)

        # Construir comando PyInstaller
        comando = [
            sys.executable, "-m", "PyInstaller",
            "--onefile",
            "--windowed",
            "--clean",
            "--noconfirm",
            f"--name={exe_name}",
            f"--distpath={dest_dir}",
            f"--workpath={temp_build}",
            f"--specpath={temp_build}",
        ]

        if icon_path:
            comando.append(f"--icon={icon_path}")
        for data in add_data:
            comando.append(f"--add-data={data}")

        comando.append(archivo)

        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"📦 Creando ejecutable en:\n{exe_path}\n\n", "titulo")
        self.output_area.insert(tk.END, f"Comando:\n{' '.join(comando)}\n\n", "resultado")
        self.output_area.see(tk.END)

        def crear():
            try:
                proceso = subprocess.run(comando, capture_output=True, text=True, timeout=300, cwd=os.path.dirname(archivo))
                if proceso.stdout:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, f"STDOUT:\n{proceso.stdout}\n", "resultado"))
                if proceso.stderr:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, f"STDERR:\n{proceso.stderr}\n", "error"))
                
                if os.path.exists(temp_build):
                    shutil.rmtree(temp_build, ignore_errors=True)
                
                if proceso.returncode == 0:
                    resultado = f"✅ Ejecutable creado exitosamente en:\n{exe_path}\n"
                    self.parent.after(0, lambda: self._mostrar_resultado(resultado, 0))
                else:
                    error_msg = f"❌ Error al crear ejecutable (código {proceso.returncode}). Revisa los mensajes arriba."
                    self.parent.after(0, lambda: self._mostrar_error(error_msg))
            except subprocess.TimeoutExpired:
                self.parent.after(0, lambda: self._mostrar_error("Timeout - La creación del EXE tardó demasiado"))
            except Exception as e:
                self.parent.after(0, lambda: self._mostrar_error(str(e)))

        threading.Thread(target=crear, daemon=True).start()
    
