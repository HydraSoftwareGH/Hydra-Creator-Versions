def get_appdata_path():
    if os.name == "nt":
        base = os.getenv("APPDATA")  # Windows
    else:
        base = os.path.expanduser("~/.config")  # Linux/Mac

    path = os.path.join(base, "HydraIA")
    os.makedirs(path, exist_ok=True)
    return path

