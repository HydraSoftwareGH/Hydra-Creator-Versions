def generar_clave():
    if not os.path.exists(KEY_FILE):
        clave = Fernet.generate_key()
        with open(KEY_FILE, "wb") as f:
            f.write(clave)
    with open(KEY_FILE, "rb") as f:
        return f.read()

def encriptar(texto, clave):
    if not texto:
        return ""
    f = Fernet(clave)
    return f.encrypt(texto.encode()).decode()

def desencriptar(texto_encriptado, clave):
    if not texto_encriptado:
        return None
    try:
        f = Fernet(clave)
        return f.decrypt(texto_encriptado.encode()).decode()
    except Exception as e:
        print(f"Error al desencriptar: {e}")
        return None

def guardar_configuracion_chat(chat_id, proveedor, modelo, api_key, emocion="Neutral", proposito="General", nombre=None):
    clave = generar_clave()
    config = {}
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            config = json.load(f)
    
    if nombre is None:
        if chat_id in config and "nombre" in config[chat_id]:
            nombre = config[chat_id]["nombre"]
        else:
            nombre = f"Chat {chat_id[:8]}"
    
    config[chat_id] = {
        "proveedor": proveedor,
        "modelo": modelo,
        "api_key": encriptar(api_key, clave),
        "nombre": nombre,
        "emocion": emocion,
        "proposito": proposito,
        "fecha_creacion": datetime.now().isoformat(),
        "fecha_ultimo_uso": datetime.now().isoformat()
    }
    
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)

def cargar_configuracion_chat(chat_id):
    if not os.path.exists(CONFIG_FILE):
        return None
    
    clave = generar_clave()
    with open(CONFIG_FILE, "r") as f:
        config = json.load(f)
    
    if chat_id not in config:
        return None
    
    data = config[chat_id].copy()
    if "api_key" in data and data["api_key"]:
        api_key_desencriptada = desencriptar(data["api_key"], clave)
        if api_key_desencriptada is None:
            return None
        data["api_key"] = api_key_desencriptada
    else:
        data["api_key"] = None
    
    if "emocion" not in data:
        data["emocion"] = "Neutral"
    if "proposito" not in data:
        data["proposito"] = "General"
    if "nombre" not in data:
        data["nombre"] = f"Chat {chat_id[:8]}"
    if "modelo" not in data:
        data["modelo"] = PROVEEDORES.get(data["proveedor"], {}).get("default_model", "gemini-2.5-flash")
    
    return data

def obtener_todos_chats():
    if not os.path.exists(CONFIG_FILE):
        return {}
    with open(CONFIG_FILE, "r") as f:
        return json.load(f)

def obtener_chat_mas_reciente():
    chats = obtener_todos_chats()
    if not chats:
        return None
    
    chats_ordenados = sorted(
        chats.items(),
        key=lambda x: x[1].get("fecha_ultimo_uso", x[1].get("fecha_creacion", "0")),
        reverse=True
    )
    
    if chats_ordenados:
        return chats_ordenados[0][0]
    return None

def actualizar_fecha_uso_chat(chat_id):
    if not os.path.exists(CONFIG_FILE):
        return
    
    with open(CONFIG_FILE, "r") as f:
        config = json.load(f)
    
    if chat_id in config:
        config[chat_id]["fecha_ultimo_uso"] = datetime.now().isoformat()
        with open(CONFIG_FILE, "w") as f:
            json.dump(config, f, indent=2)

def guardar_historial(chat_id, historial):
    data = {}
    if os.path.exists(HISTORIAL_FILE):
        with open(HISTORIAL_FILE, "r") as f:
            data = json.load(f)
    
    data[chat_id] = historial
    
    with open(HISTORIAL_FILE, "w") as f:
        json.dump(data, f, indent=2)

def cargar_historial(chat_id):
    if not os.path.exists(HISTORIAL_FILE):
        return []
    
    with open(HISTORIAL_FILE, "r") as f:
        data = json.load(f)
    
    return data.get(chat_id, [])

