# ==================================================
FIRST_RUN_FLAG = os.path.join(APPDATA_DIR, "hydra_first_run.flag")

def es_primera_ejecucion():
    """Devuelve True si es la primera vez que se ejecuta el programa."""
    return not os.path.exists(FIRST_RUN_FLAG)

def marcar_primera_ejecucion_completada():
    """Crea el archivo de flag para indicar que ya no es la primera vez."""
    with open(FIRST_RUN_FLAG, "w") as f:
        f.write(datetime.now().isoformat())

def mostrar_splash():
    """Muestra una ventana pequeña de carga con barra de progreso simulada (solo primera vez)."""
    splash = tk.Tk()
    splash.title("Hydra Creator")
    splash.geometry("400x150")
    splash.resizable(False, False)
    splash.configure(bg="#1e1e2e")
    
    # Centrar la ventana
    splash.update_idletasks()
    x = (splash.winfo_screenwidth() // 2) - (400 // 2)
    y = (splash.winfo_screenheight() // 2) - (150 // 2)
    splash.geometry(f"400x150+{x}+{y}")
    
    estilo = ttk.Style()
    estilo.theme_use('clam')
    estilo.configure("TProgressbar", thickness=20, background="#50fa7b", troughcolor="#2d2d3d")
    
    lbl_titulo = tk.Label(splash, text="Preparando Hydra Creator...", font=("Segoe UI", 12, "bold"),
                          bg="#1e1e2e", fg="#50fa7b")
    lbl_titulo.pack(pady=(20, 10))
    
    progress = ttk.Progressbar(splash, length=300, mode='determinate', style="TProgressbar")
    progress.pack(pady=10)
    
    lbl_estado = tk.Label(splash, text="Cargando...", font=("Segoe UI", 10),
                          bg="#1e1e2e", fg="#e0e0e0")
    lbl_estado.pack()
    
    # Simulación de progreso (no se descarga nada real)
    def actualizar_progreso(actual=0, incremento=10):
        if actual < 100:
            nuevo = min(actual + incremento, 100)
            progress['value'] = nuevo
            lbl_estado.config(text=f"{nuevo}% completado")
            splash.update()
            splash.after(50, actualizar_progreso, nuevo, incremento)
        else:
            splash.destroy()
            # Marcar que ya no es primera ejecución
            marcar_primera_ejecucion_completada()
            lanzar_aplicacion()
    
    splash.after(100, actualizar_progreso)
    splash.mainloop()

def lanzar_aplicacion():
    """Instancia y ejecuta la aplicación principal HydraCreator."""
    root = tk.Tk()
    app = HydraCreator(root)
    root.mainloop()

# ==================================================
# PUNTO DE ENTRADA PRINCIPAL MODIFICADO
# ==================================================
if __name__ == "__main__":
    if es_primera_ejecucion():
        mostrar_splash()
    else:
        lanzar_aplicacion()
