                api_key = simpledialog.askstring("API Key", "Nueva API Key:", show="*")
                if api_key:
                    modelo = PROVEEDORES[nuevo]["default_model"]
                    guardar_configuracion_chat(self.chat_id, nuevo, modelo, api_key,
                                               config.get("emocion", "Neutral"), config.get("proposito", "General"),
                                               config.get("nombre", self.nombre))
                    app = self.parent.master.master.master.master
                    app.clientes_ia[self.chat_id] = IAClient(nuevo, api_key, modelo)
                    messagebox.showinfo("OK", "Proveedor cambiado")
    
    def limpiar_chat(self):
        if messagebox.askyesno("Confirmar", "¿Limpiar todo el chat?"):
            app = self.parent.master.master.master.master
            if self.chat_id in app.historiales:
                app.historiales[self.chat_id] = []
                guardar_historial(self.chat_id, [])
            if app.chat_actual == self.chat_id:
                app.chat_area.config(state=tk.NORMAL)
                app.chat_area.delete(1.0, tk.END)
                app.chat_area.config(state=tk.DISABLED)
            messagebox.showinfo("Éxito", "Chat limpiado correctamente")
    
    def borrar_chat(self):
        if messagebox.askyesno("Confirmar", "¿Borrar este chat?"):
            app = self.parent.master.master.master.master
            if os.path.exists(CONFIG_FILE):
                with open(CONFIG_FILE, "r") as f:
                    config = json.load(f)
                if self.chat_id in config:
                    del config[self.chat_id]
                with open(CONFIG_FILE, "w") as f:
                    json.dump(config, f, indent=2)
            if os.path.exists(HISTORIAL_FILE):
                with open(HISTORIAL_FILE, "r") as f:
                    data = json.load(f)
                if self.chat_id in data:
                    del data[self.chat_id]
                with open(HISTORIAL_FILE, "w") as f:
                    json.dump(data, f, indent=2)
            if self.chat_id in app.historiales:
                del app.historiales[self.chat_id]
            if self.chat_id in app.clientes_ia:
                del app.clientes_ia[self.chat_id]
            if self.chat_id in app.chats:
                del app.chats[self.chat_id]
            if self in app.widgets_chats:
                app.widgets_chats.remove(self)
            self.frame.destroy()
            if app.chat_actual == self.chat_id:
                app.chat_actual = None
                app.chat_area.config(state=tk.NORMAL)
                app.chat_area.delete(1.0, tk.END)
                app.chat_area.config(state=tk.DISABLED)
                app.chat_titulo.config(text="Selecciona un chat")
                app.chat_info.config(text="")
            app.canvas_chats.configure(scrollregion=app.canvas_chats.bbox("all"))
            app.canvas_chats.update_idletasks()
            messagebox.showinfo("Éxito", "Chat borrado correctamente")

