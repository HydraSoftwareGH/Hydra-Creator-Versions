class IAClient:
    def __init__(self, proveedor, api_key, modelo=None):
        self.proveedor = proveedor
        self.api_key = api_key
        self.modelo = modelo or PROVEEDORES[proveedor]["default_model"]
        
    def enviar_mensaje_con_historial(self, mensaje, historial, emocion, proposito):
        if not self.api_key:
            return f"Error: No hay API Key configurada para {self.proveedor}."
        
        historial_texto = ""
        for msg in historial[-10:]:
            if msg["rol"] == "usuario":
                historial_texto += f"Usuario: {msg['texto']}\n"
            else:
                historial_texto += f"Asistente: {msg['texto']}\n"
        
        mensaje_completo = f"""
Actúa como una IA {emocion} especializada en {proposito}.
Responde de forma clara, útil y coherente.

=== HISTORIAL RECIENTE ===
{historial_texto}
=== FIN DEL HISTORIAL ===

Usuario: {mensaje}

Asistente:"""
        
        if self.proveedor == "gemini":
            return self._enviar_gemini(mensaje_completo)
        elif self.proveedor == "openai":
            return self._enviar_openai(mensaje_completo)
        elif self.proveedor == "groq":
            return self._enviar_groq(mensaje_completo)
        elif self.proveedor == "claude":
            return self._enviar_claude(mensaje_completo)
        elif self.proveedor == "deepseek":
            return self._enviar_deepseek(mensaje_completo)
        
        return "Proveedor no soportado"
    
    def enviar_mensaje(self, mensaje):
        return self.enviar_mensaje_con_historial(mensaje, [], "Neutral", "General")
    
    def generar_codigo_con_ia(self, descripcion, lenguaje):
        if not self.api_key:
            return None
        
        prompt = f"""Genera código en {lenguaje} para la siguiente descripción:
{descripcion}

REGLAS:
1. El código debe ser funcional y ejecutable
2. Incluye comentarios explicativos
3. Responde SOLO con el código, sin explicaciones adicionales
4. Usa las mejores prácticas de {lenguaje}

Código generado:"""
        
        if self.proveedor == "gemini":
            return self._enviar_gemini_conversion(prompt)
        elif self.proveedor == "openai":
            return self._enviar_openai_conversion(prompt)
        elif self.proveedor == "groq":
            return self._enviar_groq_conversion(prompt)
        elif self.proveedor == "claude":
            return self._enviar_claude_conversion(prompt)
        elif self.proveedor == "deepseek":
            return self._enviar_deepseek_conversion(prompt)
        
        return None
    
    def convertir_codigo_con_ia(self, codigo_original, lenguaje_origen, lenguaje_destino):
        if not self.api_key:
            return None
        
        prompt = f"""Convierte el siguiente código de {lenguaje_origen} a {lenguaje_destino}.

REGLAS:
1. El código convertido DEBE ser funcional
2. Adapta todas las funciones manteniendo la misma lógica
3. Usa la sintaxis correcta de {lenguaje_destino}
4. NO incluyas explicaciones, SOLO el código

Código original ({lenguaje_origen}):
{codigo_original}

Código convertido a {lenguaje_destino}:"""
        
        if self.proveedor == "gemini":
            return self._enviar_gemini_conversion(prompt)
        elif self.proveedor == "openai":
            return self._enviar_openai_conversion(prompt)
        elif self.proveedor == "groq":
            return self._enviar_groq_conversion(prompt)
        elif self.proveedor == "claude":
            return self._enviar_claude_conversion(prompt)
        elif self.proveedor == "deepseek":
            return self._enviar_deepseek_conversion(prompt)
        
        return None
    
    def corregir_codigo_con_ia(self, codigo, lenguaje, error_msg, intento):
        if not self.api_key:
            return None
        
        prompt = f"""El siguiente código en {lenguaje} falló al ejecutarse con el error:

{error_msg}

Código original:
{codigo}

Corrige el código para que sea funcional y ejecutable. Devuelve SOLO el código corregido, sin explicaciones.
Intento de corrección #{intento}."""
        
        if self.proveedor == "gemini":
            return self._enviar_gemini_conversion(prompt)
        elif self.proveedor == "openai":
            return self._enviar_openai_conversion(prompt)
        elif self.proveedor == "groq":
            return self._enviar_groq_conversion(prompt)
        elif self.proveedor == "claude":
            return self._enviar_claude_conversion(prompt)
        elif self.proveedor == "deepseek":
            return self._enviar_deepseek_conversion(prompt)
        return None
    
    def _extraer_codigo_de_respuesta(self, respuesta):
        patron = r'```(?:\w+)?\n([\s\S]*?)```'
        matches = re.findall(patron, respuesta)
        if matches:
            return matches[0].strip()
        return respuesta.strip()
    
    def _enviar_gemini_conversion(self, mensaje):
        try:
            import google.generativeai as genai
            genai.configure(api_key=self.api_key)
            model = genai.GenerativeModel(self.modelo)
            response = model.generate_content(mensaje)
            return self._extraer_codigo_de_respuesta(response.text)
        except Exception as e:
            return None
    
    def _enviar_openai_conversion(self, mensaje):
        try:
            from openai import OpenAI
            client = OpenAI(api_key=self.api_key)
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return self._extraer_codigo_de_respuesta(response.choices[0].message.content)
        except Exception as e:
            return None
    
    def _enviar_groq_conversion(self, mensaje):
        try:
            from groq import Groq
            client = Groq(api_key=self.api_key)
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return self._extraer_codigo_de_respuesta(response.choices[0].message.content)
        except Exception as e:
            return None
    
    def _enviar_claude_conversion(self, mensaje):
        try:
            import anthropic
            client = anthropic.Anthropic(api_key=self.api_key)
            response = client.messages.create(
                model=self.modelo,
                max_tokens=4096,
                messages=[{"role": "user", "content": mensaje}]
            )
            return self._extraer_codigo_de_respuesta(response.content[0].text)
        except Exception as e:
            return None
    
    def _enviar_deepseek_conversion(self, mensaje):
        try:
            from openai import OpenAI
            client = OpenAI(api_key=self.api_key, base_url="https://api.deepseek.com/v1")
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return self._extraer_codigo_de_respuesta(response.choices[0].message.content)
        except Exception as e:
            return None
    
    def _enviar_gemini(self, mensaje):
        try:
            import google.generativeai as genai
            genai.configure(api_key=self.api_key)
            model = genai.GenerativeModel(self.modelo)
            response = model.generate_content(mensaje)
            return response.text
        except Exception as e:
            return f"Error Gemini: {str(e)}"
    
    def _enviar_openai(self, mensaje):
        try:
            from openai import OpenAI
            client = OpenAI(api_key=self.api_key)
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return response.choices[0].message.content
        except Exception as e:
            return f"Error OpenAI: {str(e)}"
    
    def _enviar_groq(self, mensaje):
        try:
            from groq import Groq
            client = Groq(api_key=self.api_key)
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return response.choices[0].message.content
        except Exception as e:
            return f"Error Groq: {str(e)}"
    
    def _enviar_claude(self, mensaje):
        try:
            import anthropic
            client = anthropic.Anthropic(api_key=self.api_key)
            response = client.messages.create(
                model=self.modelo,
                max_tokens=4096,
                messages=[{"role": "user", "content": mensaje}]
            )
            return response.content[0].text
        except Exception as e:
            return f"Error Claude: {str(e)}"
    
    def _enviar_deepseek(self, mensaje):
        try:
            from openai import OpenAI
            client = OpenAI(api_key=self.api_key, base_url="https://api.deepseek.com/v1")
            response = client.chat.completions.create(
                model=self.modelo,
                messages=[{"role": "user", "content": mensaje}]
            )
            return response.choices[0].message.content
        except Exception as e:
            return f"Error DeepSeek: {str(e)}"

