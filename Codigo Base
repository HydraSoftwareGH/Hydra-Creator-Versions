    def _extraer_codigo(self, texto):
        patron = r'```(?:\w+)?\n([\s\S]*?)```'
        matches = re.findall(patron, texto)
        if matches:
            return matches[0].strip()
        
        lineas = texto.split('\n')
        codigo = []
        for linea in lineas:
            if not linea.startswith('✅') and not linea.startswith('─') and not linea.startswith('🤖'):
                codigo.append(linea)
        return '\n'.join(codigo).strip()
    
    def _copiar_texto(self, texto):
        try:
            pyperclip.copy(texto)
            self.output_area.insert(tk.END, "✅ Texto copiado al portapapeles\n", "resultado")
            self.output_area.see(tk.END)
        except:
            self.parent.clipboard_clear()
            self.parent.clipboard_append(texto)
            self.output_area.insert(tk.END, "✅ Texto copiado al portapapeles\n", "resultado")
    
    def _mostrar_resultado(self, resultado, codigo=0):
        self.output_area.delete("1.0", tk.END)
        if codigo == 0:
            self.output_area.insert(tk.END, "✅ EJECUCIÓN EXITOSA:\n", "titulo")
            self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
            self.output_area.insert(tk.END, resultado + "\n", "resultado")
        else:
            self.output_area.insert(tk.END, "❌ ERROR:\n", "error")
            self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
            self.output_area.insert(tk.END, resultado + "\n", "error")
        self.output_area.see(tk.END)
    
    def _mostrar_error(self, error):
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"❌ ERROR: {error}\n", "error")
        self.output_area.see(tk.END)

