    def cambiar_nombre(self, proyecto_id):
        nuevo_nombre = simpledialog.askstring("Cambiar Nombre", "Nuevo nombre:")
        if nuevo_nombre:
            self.proyectos[proyecto_id]["nombre"] = nuevo_nombre
            guardar_proyectos(self.proyectos)
            self.cargar_proyectos_lista()
            if self.proyecto_actual == proyecto_id:
                self.on_select_proyecto(proyecto_id, self.proyectos[proyecto_id])
    
    def eliminar_proyecto(self, proyecto_id):
        if messagebox.askyesno("Eliminar", f"¿Eliminar proyecto '{self.proyectos[proyecto_id]['nombre']}'?"):
            ruta = self.proyectos[proyecto_id].get("ruta")
            if ruta and os.path.exists(ruta):
                shutil.rmtree(ruta, ignore_errors=True)
            del self.proyectos[proyecto_id]
            guardar_proyectos(self.proyectos)
            
            if self.proyecto_actual == proyecto_id:
                self.proyecto_actual = None
                if HydraCreator.instance and HydraCreator.instance.editor_actual:
                    HydraCreator.instance.editor_actual.frame.destroy()
                    HydraCreator.instance.editor_actual = None
                if HydraCreator.instance and HydraCreator.instance.modo_actual == "proyectos":
                    HydraCreator.instance.chat_frame.pack(fill=tk.BOTH, expand=True)
            
            self.cargar_proyectos_lista()
    
