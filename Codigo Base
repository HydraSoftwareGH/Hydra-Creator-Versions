        self.code_test_panel = None
        if self.modo_actual == "chats":
            self.chat_frame.pack(fill=tk.BOTH, expand=True)
    
    def copiar_codigo(self, codigo):
        try:
            pyperclip.copy(codigo)
            self.mostrar_notificacion("✅ Código copiado!")
        except:
            self.root.clipboard_clear()
            self.root.clipboard_append(codigo)
            self.mostrar_notificacion("✅ Código copiado!")
    
    def mostrar_configuracion_chat(self):
        VentanaConfiguracionChat(self.root, self.crear_nuevo_chat)
    
    def crear_nuevo_chat(self, nombre, proveedor, modelo, api_key, emocion, propositos):
        import time
        chat_id = str(int(time.time()))
        proposito_str = ", ".join(propositos)
        
        guardar_configuracion_chat(chat_id, proveedor, modelo, api_key, emocion, proposito_str, nombre)
        self.crear_chat_widget(chat_id, nombre)
        self.clientes_ia[chat_id] = IAClient(proveedor, api_key, modelo)
        self.historiales[chat_id] = []
        self.emociones[chat_id] = emocion
        self.propositos[chat_id] = proposito_str
        
        self.seleccionar_chat(chat_id)
    
    def mostrar_notificacion(self, mensaje, es_error=False):
        color = "#ff5555" if es_error else "#50fa7b"
        self.status_label.config(text=mensaje, fg=color)
        self.root.after(2000, lambda: self.status_label.config(text="Hydra Creator lista", fg="#50fa7b"))
    
    def agregar_mensaje(self, quien, texto, es_usuario=False):
        if not self.chat_actual:
            return
        
        self.chat_area.config(state=tk.NORMAL)
        tag = "usuario" if es_usuario else "asistente"
        self.chat_area.insert(tk.END, f"\n{quien}\n", tag)
        self.chat_area.insert(tk.END, "─" * 40 + "\n", "normal")
        self._insertar_texto_con_codigo(texto)
        self.chat_area.insert(tk.END, "\n", "normal")
        self.chat_area.config(state=tk.DISABLED)
        self.chat_area.see(tk.END)
        
        self.historiales[self.chat_actual].append({
            "rol": "usuario" if es_usuario else "asistente",
            "nombre": quien,
            "texto": texto
        })
        guardar_historial(self.chat_actual, self.historiales[self.chat_actual])
    
    def enviar_mensaje_event(self, event):
        if not event.state & 0x1:
            self.enviar_mensaje()
            return "break"
    
    def enviar_mensaje(self):
        if not self.chat_actual:
            self.mostrar_notificacion("Selecciona un chat primero")
            return
        
        mensaje = self.entrada.get("1.0", tk.END).strip()
        if not mensaje:
            return
        
        self.entrada.delete("1.0", tk.END)
        self.agregar_mensaje("👤 Tú", mensaje, es_usuario=True)
        
        self.boton_enviar.config(state=tk.DISABLED, text="💭 Pensando...")
        self.mostrar_notificacion("Hydra Creator está pensando...")
        self.root.update()
        
        def obtener():
            cliente = self.clientes_ia.get(self.chat_actual)
            if cliente:
                historial = self.historiales.get(self.chat_actual, [])[-10:]
                emocion = self.emociones.get(self.chat_actual, "Neutral")
                proposito = self.propositos.get(self.chat_actual, "General")
                respuesta = cliente.enviar_mensaje_con_historial(mensaje, historial, emocion, proposito)
                self.root.after(0, lambda: self._mostrar_respuesta(respuesta))
        
        threading.Thread(target=obtener, daemon=True).start()
    
    def _mostrar_respuesta(self, respuesta):
        self.agregar_mensaje("🐍 Hydra Creator", respuesta, es_usuario=False)
        self.boton_enviar.config(state=tk.NORMAL, text="📤 Enviar (Enter)")
        self.mostrar_notificacion("Respuesta recibida")
        self.entrada.focus_set()

