            self.output_area.insert(tk.END, f"❌ Error al abrir HTML: {str(e)}\n", "error")
        
        self.output_area.insert(tk.END, "\n📝 CONTENIDO HTML:\n", "titulo")
        self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
        self.output_area.insert(tk.END, codigo + "\n", "resultado")
        self.output_area.see(tk.END)
    
    def ejecutar_generico(self, codigo, lenguaje):
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"⚠️ EJECUCIÓN PARA {lenguaje.upper()}:\n", "titulo")
        self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
        self.output_area.insert(tk.END, f"\n📝 Para ejecutar código {lenguaje}:\n", "resultado")
        self.output_area.insert(tk.END, f"1. Guarda el archivo con extensión .{lenguaje}\n", "resultado")
        self.output_area.insert(tk.END, f"2. Ejecútalo con el intérprete correspondiente\n\n", "resultado")
        self.output_area.insert(tk.END, "📝 CÓDIGO ACTUAL:\n", "titulo")
        self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
        self.output_area.insert(tk.END, codigo + "\n", "resultado")
        self.output_area.see(tk.END)
    
    def limpiar_salida(self):
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, "✅ Listo para ejecutar código...\n")
    
    def copiar_codigo(self):
        codigo = self.code_editor.get("1.0", tk.END).strip()
        try:
            pyperclip.copy(codigo)
            self.output_area.insert(tk.END, "✅ Código copiado al portapapeles\n")
            self.output_area.see(tk.END)
        except:
            self.parent.clipboard_clear()
            self.parent.clipboard_append(codigo)
            self.output_area.insert(tk.END, "✅ Código copiado al portapapeles\n")
            self.output_area.see(tk.END)
    
    def guardar_codigo(self):
        codigo = self.code_editor.get("1.0", tk.END).strip()
        lenguaje = self.lenguaje_actual
        
        extensiones = {
            "python": ".py", "javascript": ".js", "bash": ".sh",
            "html": ".html", "css": ".css", "json": ".json",
            "sql": ".sql", "java": ".java", "cpp": ".cpp",
            "csharp": ".cs", "php": ".php", "ruby": ".rb", "go": ".go"
        }
        
        extension = extensiones.get(lenguaje, ".txt")
        nombre_archivo = f"codigo_{datetime.now().strftime('%Y%m%d_%H%M%S')}{extension}"
        
        archivo = filedialog.asksaveasfilename(
            defaultextension=extension,
            initialfile=nombre_archivo,
            filetypes=[(f"{lenguaje.upper()} files", f"*{extension}"), ("Todos los archivos", "*.*")]
        )
        
        if archivo:
            try:
                with open(archivo, "w", encoding="utf-8") as f:
                    f.write(codigo)
                self.output_area.insert(tk.END, f"✅ Guardado: {os.path.basename(archivo)}\n")
                self.output_area.see(tk.END)
            except Exception as e:
                self.output_area.insert(tk.END, f"❌ Error al guardar: {str(e)}\n", "error")
                self.output_area.see(tk.END)
    
    def salir(self):
        self.frame.destroy()
        if self.on_close:
            self.on_close()

