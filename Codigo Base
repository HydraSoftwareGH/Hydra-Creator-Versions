    def seleccionar_chat(self, chat_id):
        self.chat_actual = chat_id
        actualizar_fecha_uso_chat(chat_id)
        
        config = cargar_configuracion_chat(chat_id)
        if config:
            nombre = config.get("nombre", f"Chat {chat_id[:8]}")
            emocion = self.emociones.get(chat_id, config.get("emocion", "Neutral"))
            proposito = self.propositos.get(chat_id, config.get("proposito", "General"))
            self.chat_titulo.config(text=nombre)
            self.chat_info.config(text=f"{PROVEEDORES[config['proveedor']]['nombre']} - {config['modelo']} | 🎭 {emocion} | 🎯 {proposito}")
        
        self.chat_area.config(state=tk.NORMAL)
        self.chat_area.delete(1.0, tk.END)
        
        if chat_id in self.historiales:
            for msg in self.historiales[chat_id]:
                tag = "usuario" if msg["rol"] == "usuario" else "asistente"
                self.chat_area.insert(tk.END, f"\n{msg['nombre']}\n", tag)
                self.chat_area.insert(tk.END, "─" * 40 + "\n", "normal")
                self._insertar_texto_con_codigo(msg["texto"])
                self.chat_area.insert(tk.END, "\n", "normal")
        
        self.chat_area.config(state=tk.DISABLED)
        self.chat_area.see(tk.END)
        self.entrada.focus_set()
    
    def _insertar_texto_con_codigo(self, texto):
        patron = r'```(\w+)?\n([\s\S]*?)```'
        matches = list(re.finditer(patron, texto))
        last_end = 0
        
        for match in matches:
            start, end = match.span()
            lenguaje = match.group(1) or "text"
            codigo = match.group(2).strip()
            
            texto_normal = texto[last_end:start].strip()
            if texto_normal:
                self.chat_area.insert(tk.END, texto_normal + "\n\n", "normal")
            
            card = self._crear_card_codigo(lenguaje, codigo)
            self.chat_area.window_create(tk.END, window=card)
            self.chat_area.insert(tk.END, "\n\n")
            last_end = end
        
        restante = texto[last_end:].strip()
        if restante:
            self.chat_area.insert(tk.END, restante + "\n", "normal")
    
    def _crear_card_codigo(self, lenguaje, codigo):
        card = tk.Frame(self.chat_area, bg="#161b22", bd=1, relief=tk.FLAT)
        header = tk.Frame(card, bg="#0d1117", height=35)
        header.pack(fill=tk.X)
        header.pack_propagate(False)
        
        lbl = tk.Label(header, text=lenguaje.capitalize(), bg="#0d1117", fg="#8b949e", font=("Segoe UI", 9, "bold"))
        lbl.pack(side=tk.LEFT, padx=10)
        
        btn_frame = tk.Frame(header, bg="#0d1117")
        btn_frame.pack(side=tk.RIGHT, padx=5)
        
        btn_copy = tk.Button(btn_frame, text="📋", command=lambda: self.copiar_codigo(codigo),
                             bg="#21262d", fg="#c9d1d9", relief=tk.FLAT, cursor="hand2", padx=6)
        btn_copy.pack(side=tk.LEFT, padx=3)
        
        btn_test = tk.Button(btn_frame, text="🧪 PROBAR", 
                              command=lambda: self.probar_codigo(codigo, lenguaje),
                              bg="#50fa7b", fg="#1e1e2e", relief=tk.FLAT, cursor="hand2", padx=6, font=("Segoe UI", 8, "bold"))
        btn_test.pack(side=tk.LEFT, padx=3)
        
        code = tk.Text(card, bg="#161b22", fg="#e6edf3", font=("Consolas", 10),
                       wrap=tk.NONE, relief=tk.FLAT, padx=10, pady=8,
                       height=min(20, codigo.count("\n") + 2))
        code.insert("1.0", codigo)
        code.config(state=tk.DISABLED)
        code.pack(fill=tk.BOTH, expand=True)
        return card
    
