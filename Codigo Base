        nombre_entry = tk.Entry(frame, font=("Segoe UI", 11), bg="#3d3d4d", fg="white", width=40)
        nombre_entry.pack(fill=tk.X, pady=5)
        
        tk.Label(frame, text="Lenguaje de programación:", font=("Segoe UI", 11),
                bg="#1e1e2e", fg="#e0e0e0").pack(anchor=tk.W, pady=5)
        
        lenguaje_var = tk.StringVar(value="python")
        lenguajes_frame = tk.Frame(frame, bg="#1e1e2e")
        lenguajes_frame.pack(fill=tk.X, pady=5)
        
        for i, (lang, config) in enumerate(LENGUAJES_CONFIG.items()):
            rb = tk.Radiobutton(lenguajes_frame, text=f"{config['icono']} {lang.upper()}", 
                                variable=lenguaje_var, value=lang,
                                bg="#1e1e2e", fg="#e0e0e0", selectcolor="#2d2d3d")
            rb.grid(row=i//3, column=i%3, sticky=tk.W, padx=10, pady=5)
        
        tk.Label(frame, text="Descripción (opcional):", font=("Segoe UI", 11),
                bg="#1e1e2e", fg="#e0e0e0").pack(anchor=tk.W, pady=5)
        desc_text = tk.Text(frame, height=4, font=("Segoe UI", 10),
                            bg="#3d3d4d", fg="white", wrap=tk.WORD)
        desc_text.pack(fill=tk.X, pady=5)
        
        def crear():
            nombre = nombre_entry.get().strip()
            if not nombre:
                messagebox.showerror("Error", "Ingresa un nombre")
                return
            
            lenguaje = lenguaje_var.get()
            descripcion = desc_text.get("1.0", tk.END).strip()
            
            desktop = os.path.join(os.path.expanduser("~"), "Desktop")
            proyecto_folder = os.path.join(desktop, f"HydraCreator_{nombre.replace(' ', '_')}")
            os.makedirs(proyecto_folder, exist_ok=True)
            
            extension = LENGUAJES_CONFIG[lenguaje]["extension"]
            archivo_principal = os.path.join(proyecto_folder, f"main{extension}")
            
            template = self._obtener_template(lenguaje, nombre)
            with open(archivo_principal, "w", encoding="utf-8") as f:
                f.write(template)
            
            proyecto_id = str(int(datetime.now().timestamp()))
            self.proyectos[proyecto_id] = {
                "nombre": nombre,
                "lenguaje": lenguaje,
                "ruta": proyecto_folder,
                "archivo_principal": archivo_principal,
                "descripcion": descripcion,
                "creado": datetime.now().isoformat()
            }
            guardar_proyectos(self.proyectos)
            self.cargar_proyectos_lista()
            ventana.destroy()
            self.seleccionar_proyecto(proyecto_id)
            messagebox.showinfo("Éxito", f"Proyecto creado en:\n{proyecto_folder}")
        
        tk.Button(frame, text="Crear Proyecto", command=crear,
                 bg="#50fa7b", fg="#1e1e2e", font=("Segoe UI", 11, "bold"),
                 padx=20, pady=8, relief=tk.FLAT, cursor="hand2").pack(pady=20)
    
    def _obtener_template(self, lenguaje, nombre):
        templates = {
            "python": f'# {nombre}\n# Creado con Hydra Creator\n\nprint("¡Hola desde {nombre}!")',
            "javascript": f'// {nombre}\n// Creado con Hydra Creator\n\nconsole.log("¡Hola desde {nombre}!");',
            "html": f'<!DOCTYPE html>\n<html>\n<head>\n    <title>{nombre}</title>\n</head>\n<body>\n    <h1>¡Hola desde {nombre}!</h1>\n</body>\n</html>',
            "cpp": f'// {nombre}\n// Creado con Hydra Creator\n\n#include <iostream>\nusing namespace std;\n\nint main() {{\n    cout << "¡Hola desde {nombre}!" << endl;\n    return 0;\n}}',
            "java": f'// {nombre}\n// Creado con Hydra Creator\n\npublic class Main {{\n    public static void main(String[] args) {{\n        System.out.println("¡Hola desde {nombre}!");\n    }}\n}}',
            "csharp": f'// {nombre}\n// Creado con Hydra Creator\n\nusing System;\n\nclass Program {{\n    static void Main() {{\n        Console.WriteLine("¡Hola desde {nombre}!");\n    }}\n}}',
            "go": f'// {nombre}\n// Creado con Hydra Creator\n\npackage main\n\nimport "fmt"\n\nfunc main() {{\n    fmt.Println("¡Hola desde {nombre}!")\n}}',
            "rust": f'// {nombre}\n// Creado con Hydra Creator\n\nfn main() {{\n    println!("¡Hola desde {nombre}!");\n}}'
        }
        return templates.get(lenguaje, f'# {nombre}\nprint("¡Hola desde {nombre}!")')

