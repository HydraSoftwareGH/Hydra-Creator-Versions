    def _obtener_cliente_rapido(self):
        if self.ia_client and self.ia_client.proveedor == "groq":
            return self.ia_client
        if hasattr(HydraCreator, 'instance') and HydraCreator.instance:
            app = HydraCreator.instance
            for chat_id, cliente in app.clientes_ia.items():
                if cliente.proveedor == "groq":
                    return cliente
        return self.ia_client
    
    def cambiar_lenguaje_con_ia(self, event=None):
        nuevo_lenguaje = self.lenguaje_var.get()
        codigo_actual = self.code_editor.get("1.0", tk.END).strip()
        
        if not codigo_actual:
            self.output_area.insert(tk.END, "❌ No hay código para convertir\n", "error")
            return
        
        if self.lenguaje_actual == nuevo_lenguaje:
            return
        
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"🤖 Usando IA para convertir de {self.lenguaje_actual} a {nuevo_lenguaje}...\n\n", "ejecutando")
        self.output_area.see(tk.END)
        
        cliente_rapido = self._obtener_cliente_rapido()
        if not cliente_rapido:
            self.output_area.insert(tk.END, "❌ No hay IA disponible para conversión.\n", "error")
            return
        
        def convertir_con_ia():
            codigo_convertido = cliente_rapido.convertir_codigo_con_ia(
                codigo_actual, self.lenguaje_actual, nuevo_lenguaje
            )
            if codigo_convertido:
                self.parent.after(0, lambda: self._aplicar_conversion(codigo_convertido, nuevo_lenguaje, cliente_rapido.proveedor))
            else:
                self.parent.after(0, lambda: self.output_area.insert(tk.END, "❌ Error en la conversión con IA\n", "error"))
        
        threading.Thread(target=convertir_con_ia, daemon=True).start()
    
    def _aplicar_conversion(self, codigo_convertido, nuevo_lenguaje, proveedor_usado):
        if codigo_convertido:
            self.code_editor.delete("1.0", tk.END)
            self.code_editor.insert("1.0", codigo_convertido)
            self.info_label.config(text=f"💡 Convertido a {nuevo_lenguaje.capitalize()} usando {proveedor_usado.upper()}")
            self.lenguaje_actual = nuevo_lenguaje
            self.output_area.delete("1.0", tk.END)
            self.output_area.insert(tk.END, f"✅ Conversión exitosa usando {proveedor_usado.upper()}\n", "titulo")
            self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
            self.output_area.insert(tk.END, codigo_convertido + "\n\n", "resultado")
            self.output_area.insert(tk.END, "✨ Ejecutando código convertido...\n", "correccion")
            self.output_area.see(tk.END)
            self.ejecutar_codigo()
        else:
            self.output_area.delete("1.0", tk.END)
            self.output_area.insert(tk.END, "❌ Error en la conversión con IA\n", "error")
        self.output_area.see(tk.END)
    
    def ejecutar_codigo(self):
        codigo = self.code_editor.get("1.0", tk.END).strip()
        lenguaje = self.lenguaje_actual
        
        if not codigo:
            self.output_area.insert(tk.END, "❌ No hay código para ejecutar\n")
            self.output_area.see(tk.END)
            return
        
        self.output_area.delete("1.0", tk.END)
        self.output_area.insert(tk.END, f"🔄 Ejecutando código {lenguaje}...\n\n", "ejecutando")
        self.output_area.see(tk.END)
        
        if lenguaje == "python":
            self.ejecutar_python_con_correccion(codigo)
        elif lenguaje == "javascript":
            self.ejecutar_javascript_con_correccion(codigo)
        elif lenguaje == "bash":
            self.ejecutar_bash_con_correccion(codigo)
        elif lenguaje == "html":
            self.ejecutar_html(codigo)
        else:
            self.ejecutar_generico(codigo, lenguaje)
    
    def ejecutar_python_con_correccion(self, codigo, intento=1):
        output_buffer = io.StringIO()
        ejecucion_exitosa = False
        resultado = ""
        error_msg = ""
        
        try:
            with contextlib.redirect_stdout(output_buffer):
                with contextlib.redirect_stderr(output_buffer):
                    exec(codigo, {"__name__": "__main__"}, {})
            
            resultado = output_buffer.getvalue()
            ejecucion_exitosa = True
            
        except Exception as e:
            error_msg = str(e)
            ejecucion_exitosa = False
        
        if ejecucion_exitosa:
            if resultado:
                self.output_area.delete("1.0", tk.END)
                self.output_area.insert(tk.END, "✅ RESULTADO (Python):\n", "titulo")
                self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
                self.output_area.insert(tk.END, resultado + "\n", "resultado")
                self.output_area.insert(tk.END, "\n✨ El código funciona correctamente!\n", "correccion")
            else:
                self.output_area.delete("1.0", tk.END)
                self.output_area.insert(tk.END, "✅ Código Python ejecutado correctamente (sin salida)\n", "resultado")
                self.output_area.insert(tk.END, "\n✨ El código funciona correctamente!\n", "correccion")
            self.corrigiendo = False
        else:
            if intento <= 3 and self.ia_client and not self.corrigiendo:
                self.corrigiendo = True
                self.intento_correccion = intento
                self.output_area.delete("1.0", tk.END)
                self.output_area.insert(tk.END, f"⚠️ Error detectado (intento {intento}):\n", "error")
                self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
                self.output_area.insert(tk.END, f"{error_msg}\n\n", "error")
                self.output_area.insert(tk.END, f"🔧 La IA está corrigiendo el código (intento {intento}/3)...\n\n", "correccion")
                self.output_area.see(tk.END)
                
                cliente_corrector = self._obtener_cliente_rapido()
                def corregir():
                    codigo_corregido = cliente_corrector.corregir_codigo_con_ia(codigo, "python", error_msg, intento) if cliente_corrector else None
                    if codigo_corregido and codigo_corregido != codigo:
                        self.parent.after(0, lambda: self._aplicar_correccion(codigo_corregido, "python", intento + 1))
                    else:
                        if intento < 3:
                            self.parent.after(0, lambda: self._reintentar_con_mismo_error(codigo, "python", error_msg, intento))
                        else:
                            self.parent.after(0, lambda: self._mostrar_error_sin_correccion(error_msg))
                
                threading.Thread(target=corregir, daemon=True).start()
            elif intento <= 3 and self.ia_client:
                self.parent.after(0, lambda: self._reintentar_con_mismo_error(codigo, "python", error_msg, intento))
            else:
                self.output_area.delete("1.0", tk.END)
                self.output_area.insert(tk.END, "❌ ERROR EN PYTHON (después de múltiples intentos):\n", "error")
                self.output_area.insert(tk.END, "─" * 40 + "\n", "linea")
                self.output_area.insert(tk.END, error_msg + "\n", "error")
                self.output_area.insert(tk.END, "\n⚠️ No se pudo corregir el código automáticamente.\n", "error")
                self.corrigiendo = False
        
        self.output_area.see(tk.END)
    
