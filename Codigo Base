        self.output_area.insert(tk.END, "=" * 50 + "\n", "exito")
        self.output_area.insert(tk.END, f"📁 Directorio: {self.proyecto_ruta if self.proyecto_ruta else 'Sistema'}\n", "info")
        if self.lenguaje:
            self.output_area.insert(tk.END, f"🔧 Lenguaje: {self.lenguaje.upper()}\n", "info")
            self.output_area.insert(tk.END, f"📦 Comandos disponibles: pip, npm, {self.lenguaje}\n", "info")
        self.output_area.insert(tk.END, "=" * 50 + "\n\n", "exito")
        self.output_area.see(tk.END)
    
    def insertar_comando(self, comando):
        self.comando_entry.delete(0, tk.END)
        self.comando_entry.insert(0, comando)
        self.comando_entry.focus_set()
    
    def ejecutar_comando(self, event=None):
        comando = self.comando_entry.get().strip()
        if not comando:
            return
        
        self.comando_entry.delete(0, tk.END)
        
        self.output_area.insert(tk.END, f"\n$> {comando}\n", "comando")
        self.output_area.see(tk.END)
        
        def ejecutar():
            try:
                cwd = self.proyecto_ruta if self.proyecto_ruta and os.path.exists(self.proyecto_ruta) else None
                
                proceso = subprocess.run(
                    comando, shell=True, capture_output=True, text=True,
                    timeout=60, cwd=cwd
                )
                
                if proceso.stdout:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, proceso.stdout, "resultado"))
                if proceso.stderr:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, proceso.stderr, "error"))
                
                if proceso.returncode == 0:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, f"\n✅ Comando ejecutado exitosamente (código: {proceso.returncode})\n", "exito"))
                else:
                    self.parent.after(0, lambda: self.output_area.insert(tk.END, f"\n❌ Error (código: {proceso.returncode})\n", "error"))
                
                self.parent.after(0, lambda: self.output_area.insert(tk.END, "\n" + "─" * 40 + "\n", "linea"))
                self.parent.after(0, lambda: self.output_area.see(tk.END))
                
            except subprocess.TimeoutExpired:
                self.parent.after(0, lambda: self.output_area.insert(tk.END, "\n❌ Timeout - El comando tardó demasiado\n", "error"))
            except Exception as e:
                self.parent.after(0, lambda: self.output_area.insert(tk.END, f"\n❌ Error: {str(e)}\n", "error"))
        
        threading.Thread(target=ejecutar, daemon=True).start()
    
    def limpiar(self):
        self.output_area.delete("1.0", tk.END)
        self.mostrar_bienvenida()

