            if lenguaje == "python":
                self.ejecutar_python_con_correccion(codigo, intento + 1)
            elif lenguaje == "javascript":
                self.ejecutar_javascript_con_correccion(codigo, intento + 1)
            elif lenguaje == "bash":
                self.ejecutar_bash_con_correccion(codigo, intento + 1)
        else:
            self._mostrar_error_sin_correccion(error_msg)
    
